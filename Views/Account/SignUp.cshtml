@model WebApplication4.Models.Player

@{
    ViewData["Title"] = "إنشاء حساب جديد";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-body">
                    <h3 class="card-title text-center mb-4">إنشاء حساب جديد</h3>

                    @if (ViewBag.Message != null)
                    {
                        <div class="alert alert-warning">@ViewBag.Message</div>
                    }

                    <form method="post" asp-action="SignUp" asp-controller="Account">
                        <div class="mb-3">
                            <label class="form-label">اسم المستخدم</label>
                            <input asp-for="Username" class="form-control" placeholder="أدخل اسم المستخدم" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">البريد الإلكتروني</label>
                            <input asp-for="Email" class="form-control" placeholder="أدخل بريدك الإلكتروني" type="email" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">كلمة المرور</label>
                            <input asp-for="Password" class="form-control" placeholder="أدخل كلمة المرور" type="password" required />
                            <small class="text-muted">يجب أن تحتوي على 8 أحرف على الأقل وحروف كبيرة وصغيرة وأرقام.</small>
                        </div>
                        <button type="submit" class="btn btn-success w-100">إنشاء الحساب</button>
                    </form>

                    <hr />
                </div>
            </div>
        </div>
    </div>
</div>
