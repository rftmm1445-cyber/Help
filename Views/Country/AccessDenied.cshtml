@{
    ViewData["Title"] = "Access Denied";
    Layout = "~/Views/Shared/_Layout.cshtml"; // adjust if your layout path is different
}

<div class="container mt-5 text-center">
    <div class="card shadow-lg border-danger mx-auto p-5" style="max-width: 500px;">
        <div class="mb-4">
            <i class="bi bi-shield-lock-fill text-danger" style="font-size: 4rem;"></i>
        </div>

        <h2 class="text-danger mb-3">Access Denied</h2>
        <p class="text-muted mb-4">
            Sorry, you don’t have permission to view this page.<br />
            Please contact the administrator or return to a safe page.
        </p>

        <div class="d-grid gap-2">
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary">
                <i class="bi bi-house-door"></i> Back to Home
            </a>
            <a asp-controller="Account" asp-action="Login" class="btn btn-primary">
                <i class="bi bi-box-arrow-in-right"></i> Go to Login
            </a>
        </div>
    </div>
</div>
