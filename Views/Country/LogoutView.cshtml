@{
    ViewData["Title"] = "Logout";
    Layout = "~/Views/Shared/_Layout.cshtml"; // change this if you use a different layout
}

<div class="container mt-5 text-center">
    <div class="card shadow-lg p-4 mx-auto" style="max-width: 400px;">
        <h2 class="text-success mb-3">You’ve Logged Out Successfully</h2>
        <p class="text-muted mb-4">Thank you for visiting. You can log in again anytime.</p>

        <a asp-controller="Account" asp-action="Login" class="btn btn-primary w-100">
            Log In Again
        </a>

        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary w-100 mt-2">
            Back to Home
        </a>
    </div>
</div>
