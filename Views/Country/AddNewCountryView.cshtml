@* @model WebApplication4.Models.Country
@{
    ViewData["Title"] = "إضافة دولة جديدة";
    var continents = ViewBag.Continents as List<WebApplication4.Models.Continent> ?? new List<WebApplication4.Models.Continent>();
}

<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-5 mx-auto p-4 dark-card" style="max-width: 800px;">
        <div class="card-header text-center py-4 rounded-top-4 dark-header">
            🌍 إضافة دولة جديدة
        </div>

        <div class="card-body">
            @if (ViewBag.Success != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @ViewBag.Success
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <form asp-action="DoAddCountry" asp-controller="Country" method="post" enctype="multipart/form-data">

                <!-- اختيار القارة -->
                <div class="mb-4">
                    <label class="form-label fw-bold text-light">القارة:</label>
                    <select asp-for="Continent_Id" class="form-select form-select-lg shadow-sm dark-input" required>
                        <option value="">اختر القارة</option>
                        @foreach (var cont in continents)
                        {
                            <option value="@cont.Id" selected="@(Model.Continent_Id == cont.Id ? "selected" : null)">@cont.Name</option>
                        }
                    </select>
                    <div class="form-text text-light">اختر القارة التي تنتمي إليها الدولة.</div>
                </div>

                <!-- اسم الدولة -->
                <div class="mb-4">
                    <label for="Country_Name" class="form-label fw-bold text-light">اسم الدولة:</label>
                    <input type="text" id="Country_Name" name="Country_Name" asp-for="Country_Name" class="form-control form-control-lg shadow-sm dark-input" placeholder="مثل: فلسطين" required />
                    <div class="form-text text-light">أدخل اسم الدولة.</div>
                </div>

                <!-- العاصمة -->
                <div class="mb-4">
                    <label for="Country_Capital" class="form-label fw-bold text-light">العاصمة:</label>
                    <input type="text" id="Country_Capital" name="Country_Capital" asp-for="Country_Capital" class="form-control form-control-lg shadow-sm dark-input" placeholder="مثل: القدس" required />
                    <div class="form-text text-light">أدخل العاصمة.</div>
                </div>

                <div class="row">
                    <!-- عدد السكان -->
                    <div class="col-md-6 mb-4">
                        <label for="Country_Population" class="form-label fw-bold text-light">عدد السكان:</label>
                        <input type="number" id="Country_Population" name="Country_Population" asp-for="Country_Population" class="form-control form-control-lg shadow-sm dark-input" min="0" required />
                        <div class="form-text text-light">أدخل العدد التقريبي لسكان الدولة.</div>
                    </div>

                    <!-- المساحة -->
                    <div class="col-md-6 mb-4">
                        <label for="Country_Area" class="form-label fw-bold text-light">المساحة (كم²):</label>
                        <input type="number" step="0.01" id="Country_Area" name="Country_Area" asp-for="Country_Area" class="form-control form-control-lg shadow-sm dark-input" min="0" required />
                        <div class="form-text text-light">أدخل المساحة الإجمالية للدولة بالكيلومتر المربع.</div>
                    </div>
                </div>

                <!-- صورة العلم -->
                <div class="mb-4">
                    @if (!string.IsNullOrEmpty(Model.Country_Flag))
                    {
                        <img src="@Model.Country_Flag" width="200" class="mb-2 rounded-2" style="object-fit:cover;" />
                    }
                    <label for="Country_Flag_File" class="form-label fw-bold text-light">صورة علم الدولة:</label>
                    <input type="file" id="Country_Flag_File" name="Country_Flag_File" class="form-control form-control-lg shadow-sm dark-input" accept="image/*" />
                    <div class="form-text text-light">اختر صورة العلم (jpg, png, gif).</div>
                </div>

                <!-- وصف الدولة -->
                <div class="mb-4">
                    <label for="Country_Description" class="form-label fw-bold text-light">وصف الدولة:</label>
                    <textarea id="Country_Description" name="Country_Description" asp-for="Country_Description" rows="5" class="form-control form-control-lg shadow-sm dark-input" placeholder="اكتب معلومات عن الدولة...">@Model.Country_Description</textarea>
                    <div class="form-text text-light">يمكنك كتابة معلومات إضافية مثل المعالم، المناخ، أو أي تفاصيل أخرى.</div>
                </div>

                <!-- أزرار -->
                <div class="text-center">
                    <button type="submit" class="btn btn-save btn-lg px-5 py-2 shadow-sm">💾 حفظ الدولة</button>
                    <a href="@Url.Action("Index", "Country")" class="btn btn-cancel btn-lg ms-3 shadow-sm">🔙 العودة</a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .dark-card {
        background: linear-gradient(rgba(0,0,50,0.85), rgba(0,0,80,0.85)), url('/Photo/world-blur.jpg');
        background-size: cover;
        background-position: center;
        color: #fff;
    }

    .dark-header {
        background: linear-gradient(135deg, #6610f2, #0d6efd);
        color: #fff;
        font-size: 1.5rem;
        font-weight: bold;
    }

    .dark-input {
        background-color: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.3);
        color: #fff;
    }

        .dark-input::placeholder {
            color: rgba(255,255,255,0.6);
        }

    .form-text {
        font-size: 0.9rem;
    }

    .btn-save {
        background: linear-gradient(45deg, #0dcaf0, #198754);
        color: #fff;
        font-weight: bold;
        border-radius: 50px;
        transition: all 0.3s;
    }

        .btn-save:hover {
            transform: translateY(-3px);
            filter: brightness(1.1);
        }

        .btn-save:active {
            transform: translateY(0);
            filter: brightness(0.9);
        }

    .btn-cancel {
        background: linear-gradient(45deg, #ffc107, #fd7e14);
        color: #fff;
        font-weight: bold;
        border-radius: 50px;
        transition: all 0.3s;
    }

        .btn-cancel:hover {
            transform: translateY(-3px);
            filter: brightness(1.1);
        }

        .btn-cancel:active {
            transform: translateY(0);
            filter: brightness(0.9);
        }

    .shadow-sm {
        box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.3) !important;
    }
</style>
