        {name:"Samarkand",latMin:39.62,latMax:39.70,lngMin:66.90,lngMax:67.08},
        {name:"Bishkek",latMin:42.82,latMax:42.90,lngMin:74.52,lngMax:74.68},
        {name:"Thimphu",latMin:27.45,latMax:27.52,lngMin:89.60,lngMax:89.68},
        {name:"Lhasa",latMin:29.62,latMax:29.70,lngMin:91.05,lngMax:91.18},
        {name:"Darwin",latMin:-12.50,latMax:-12.38,lngMin:130.80,lngMax:130.92},
        {name:"Alice Springs",latMin:-23.75,latMax:-23.65,lngMin:133.82,lngMax:133.95},
        {name:"Reunion",latMin:-20.92,latMax:-20.82,lngMin:55.42,lngMax:55.55}
      ]
    };

    // ======== متغيرات اللعبة ========
    let realLat=0, realLng=0, roundActive=false, timer=null, timeLeft=60, totalPoints=0;
    const miniMap = L.map('miniMap').setView([0,0], 2);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution:'© OpenStreetMap' }).addTo(miniMap);
    const guessMarker = L.marker([0,0], {draggable:true}).addTo(miniMap);
    let realMarker=null, connectingLine=null;

    miniMap.on('click', e => { if(roundActive) guessMarker.setLatLng(e.latlng); });
    const miniMapDiv=document.getElementById('miniMap');
    miniMapDiv.addEventListener('mouseenter', ()=>setTimeout(()=>miniMap.invalidateSize(),310));
    miniMapDiv.addEventListener('mouseleave', ()=>setTimeout(()=>miniMap.invalidateSize(),310));

    function updateStreetView(lat,lng){
        document.getElementById("streetViewFrame").src=
        `https://maps.google.com/maps?layer=c&cbll=${lat},${lng}&cbp=11,0,0,0,0&output=svembed`;
    }

    function getRandomLatLng(){
        const difficulty = document.getElementById("difficulty").value;
        const areas = allAreas[difficulty];
        const area = areas[Math.floor(Math.random()*areas.length)];
        const lat = getRandomCoordinate(area.latMin,area.latMax);
        const lng = getRandomCoordinate(area.lngMin,area.lngMax);
        return {lat,lng,area:area.name};
    }

    // ======== بدء الجولة ========
    function startRound(){
        if(roundActive){
            if(!confirm("الجولة الحالية لم تنته بعد. هل تريد بدء جولة جديدة؟")) return;
            clearInterval(timer);
        }

        const {lat,lng}=getRandomLatLng();
        realLat=parseFloat(lat);
        realLng=parseFloat(lng);
        updateStreetView(realLat,realLng);
        guessMarker.setLatLng([0,0]);
        miniMap.setView([0,0],2);
        if(realMarker){ miniMap.removeLayer(realMarker); realMarker=null; }
        if(connectingLine){ miniMap.removeLayer(connectingLine); connectingLine=null; }

        roundActive=true;
        timeLeft=60;
        document.getElementById("points").innerText="";
        document.getElementById("timer").innerText=`الوقت المتبقي: ${timeLeft}`;
        if(timer) clearInterval(timer);
        timer=setInterval(()=>{
            timeLeft--;
            document.getElementById("timer").innerText=`الوقت المتبقي: ${timeLeft}`;
            if(timeLeft<=0) endRound();
        },1000);
    }

    // ======== تحقق من التخمين ========
    function checkGuess(){
        if(!roundActive) return;
        const guessPos=guessMarker.getLatLng();
        const distance=getDistanceFromLatLonInKm(realLat,realLng,guessPos.lat,guessPos.lng);
        const points=calculatePoints(distance);
        document.getElementById("points").innerText=`مسافة تخمينك الحالية: ${distance.toFixed(2)} كم | نقاط محتملة: ${points}`;
    }
    //تعديل عدد النقاط بعد ان ينهي اللاعب الجولات
    function endgame() 
    {
        ViewBag.CurrentPlayer.SavePlayerProgress(ViewBag.CurrentPlayer.Id,ViewBag.CurrentPlayer.Score+points,ViewBag.CurrentPlayer.pLevel);

        
        
    }

    // ======== إنهاء الجولة ========
    function endRound(){
        clearInterval(timer);
        roundActive=false;

        const guessPos=guessMarker.getLatLng();
        const distance=getDistanceFromLatLonInKm(realLat,realLng,guessPos.lat,guessPos.lng);
        const points=calculatePoints(distance);
        totalPoints+=points;

        miniMap.setView([realLat,realLng],4);
        document.getElementById("points").innerText=`نقاط هذه الجولة: ${points} | مسافة التخمين: ${distance.toFixed(2)} كم`;
        document.getElementById("totalPoints").innerText=`النقاط الكلية: ${totalPoints}`;

        realMarker=L.marker([realLat,realLng], {icon:L.icon({iconUrl:'https://cdn-icons-png.flaticon.com/512/252/252025.png', iconSize:[30,30]})}).addTo(miniMap);
        connectingLine=L.polyline([guessPos,[realLat,realLng]], {color:'red'}).addTo(miniMap);
    }

    // ======== بدء الجولة تلقائياً عند التحميل ========
    startRound();
</script>
