<style>
    html, body {
        -- margin: 0;
        padding: 0;
        height: 100%;
        width: 100%;
        overflow: hidden;
        font-family: Arial, sans-serif;
    }

    #streetViewFrame {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        border: 0;
        z-index: 1;
    }

    #controls {
        position: fixed;
        top: 10px;
        left: 10px;
        background: rgba(255,255,255,0.9);
        padding: 10px;
        border-radius: 5px;
        z-index: 1000;
    }

        #controls button, #controls select {
            margin-top: 5px;
            width: 150px;
        }

    #miniMap {
        position: fixed;
        bottom: 10px;
        right: 10px;
        width: 300px;
        height: 200px;
        border: 2px solid #333;
        z-index: 1000;
        background: white;
        transition: width 0.3s ease, height 0.3s ease, bottom 0.3s ease, right 0.3s ease, box-shadow 0.3s ease;
        transform-origin: bottom right;
    }

        #miniMap:hover {
            width: 600px;
            height: 400px;
            bottom: 20px;
            right: 20px;
            box-shadow: 0 12px 30px rgba(0,0,0,0.45);
        }

    #timer, #points, #totalPoints {
        font-weight: bold;
        margin-top: 5px;
    }

    #timer {
        color: #333;
    }

    #points {
        color: green;
    }

    #totalPoints {
        color: blue;
    }
</style>

<div id="controls">
    <label>
        @if (ViewBag.CurrentPlayer!= null)
        {
            <p>مرحباً، @ViewBag.CurrentPlayer.Username</p>
        }
        اختر مستوى الصعوبة:
        <select id="difficulty">
            <option value="easy">سهل</option>
            <option value="medium">متوسط</option>
            <option value="hard">صعب</option>
        </select>
    </label>
    <br>
    <button onclick="startRound()" id="startBtn">ابدأ الجولة</button>
    <button onclick="checkGuess()" id="checkBtn">تحقق من التخمين</button>
    <button onclick="endgame()" id="checkBtn">انهاء اللعبة</button>
    <div id="timer">الوقت المتبقي: 60</div>
    <div id="points"></div>
    <div id="totalPoints">النقاط الكلية: 0</div>
</div>

<iframe id="streetViewFrame" allowfullscreen loading="lazy"></iframe>
<div id="miniMap"></div>

