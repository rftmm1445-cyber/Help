@* @model WebApplication4.Models.PlayerHubViewModel
@{
    ViewData["Title"] = "Player Hub";
    string firstChar = string.IsNullOrWhiteSpace(Model.Username) ? "?" : Model.Username.Trim()[0].ToString().ToUpper();
}

<link rel="stylesheet" href="~/css/playerhub-light.css" />

<style>
    /* ==========================
       خلفية ديناميكية وحيوية
       ========================== */
    body {
        margin: 0;
        font-family: "Segoe UI", Tahoma, Arial;
        background: radial-gradient(ellipse at top left, #6dd5ed, #2193b0), linear-gradient(120deg, rgba(255,255,255,0.1), transparent);
        color: #1b2b3a;
        overflow-x: hidden;
        background-size: 200% 200%;
        animation: bgMove 60s linear infinite;
    }

   

    50% {
        background-position: 50% 50%;
    }

    100% {
        background-position: 0% 0%;
    }

    }

    /* تحسين عناصر UI */
    .panel-body {
        background: rgba(255,255,255,0.6);
        border-radius: 14px;
        padding: 14px;
        backdrop-filter: blur(6px);
    }

    .btn-start {
        background: linear-gradient(180deg,#7fd35b,#4fa83a);
        color: #153018;
        font-weight: 900;
        font-size: 22px;
        border-radius: 14px;
        box-shadow: 0 10px 26px rgba(79,168,58,.35);
        cursor: pointer;
    }

    .btn-soft {
        background: rgba(255,255,255,.8);
        border-radius: 12px;
        font-weight: 900;
        cursor: pointer;
    }
</style>

<div class="page">

    <!-- TOP BAR -->
    <div class="topbar">
        <div class="idbox">
            <div class="avatar">
                <span>@firstChar</span>
            </div>
            <div class="hello">
                <div class="t1">مرحباً بك، @Model.Username</div>
                <div class="t2">جاهز لتحدّي جديد؟</div>
            </div>
        </div>

        <div class="mini-cards">
            <div class="mini">
                <div class="mini-head">⚡ السكور</div>
                <div class="mini-val">@Model.Score</div>
            </div>
            <div class="mini">
                <div class="mini-head">💠 المستوى</div>
                <div class="mini-val">@Model.Level</div>
            </div>
            <div class="mini">
                <div class="mini-head">🏅 ترتيبك</div>
                <div class="mini-val">@Model.Rank</div>
            </div>
        </div>
    </div>

    <!-- MIDDLE GRID -->
    <div class="grid3">

        <!-- LEFT: DAILY QUEST -->
        <div class="panel">
            <div class="panel-title">عجلة حظ المهام اليومية</div>
            <div class="panel-body">
                <div class="wheel-wrap">

                    <!-- العجلة -->
                    <div class="wheel-area">
                        <div class="wheel-pointer" title="المؤشر"></div>
                        <div class="wheel" id="dailyWheel" aria-label="عجلة المهام">
                            <div class="wheel-center">🎯</div>
                        </div>
                    </div>

                    <!-- التحكم + النتيجة -->
                    <div class="wheel-controls">
                        <div class="wheel-desc">
                            لف العجلة لتحصل على مهمة اليوم. ستبقى نفس المهمة طوال اليوم ✅
                        </div>

                        <button type="button" class="btn-start" id="spinBtn">
                            لف العجلة
                        </button>

                        <div class="task-box" id="taskBox" style="display:none;">
                            <div class="task-title">مهمة اليوم:</div>
                            <div class="task-text" id="taskText"></div>
                            <div class="task-note" id="taskNote"></div>
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <!-- CENTER: MAP -->
        <div class="center">
            <div class="hintbar">📍 خمن الموقع على الخريطة، ثم اضغط ابدأ الجولة</div>

            <div class="mapwrap">
                <div class="mapframe">
                    <img src="~/images/map-preview.png" class="mapimg" alt="Map Preview" />
                    <div class="pin"></div>
                    <div class="ring"></div>
                </div>

                <button type="button" class="btn-start">ابدأ الجولة</button>
            </div>
        </div>

        <!-- RIGHT: PROFILE -->
        <div class="panel">
            <div class="panel-title">الملف الشخصي</div>
            <div class="panel-body">
                <div class="profile">
                    <div class="p-avatar">@firstChar</div>
                    <div class="p-info">
                        <div class="p-name">@Model.Username</div>
                        <div class="p-sub">Level @Model.Level • Score @Model.Score</div>
                    </div>
                </div>

                <div class="row2">
                    <a class="btn-soft" href="/Player/Profile">عرض</a>
                    <a class="btn-soft" href="/Player/Edit">تعديل</a>
                </div>

                <a class="btn-logout" href="/Account/Logout">تسجيل الخروج</a>
            </div>
        </div>

    </div>

    <!-- BOTTOM GRID -->
    <div class="grid3 bottom">

        <!-- Leaderboard table -->
        <div class="panel">
            <div class="panel-title">المتصدرون</div>
            <div class="panel-body">
                <table class="lb">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>الاسم</th>
                            <th>السكور</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model.TopPlayers)
                        {
                            <tr>
                                <td>@p.Position</td>
                                <td>@p.Username</td>
                                <td class="r">@p.Score</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Top 5 avatars -->
        <div class="panel">
            <div class="panel-title">Top 5 (المتصدرين)</div>
            <div class="panel-body">
                <div class="chips">
                    @foreach (var p in Model.TopPlayers)
                    {
                        var c = string.IsNullOrWhiteSpace(p.Username) ? "?" : p.Username.Trim()[0].ToString().ToUpper();
                        <div class="chip">@c</div>
                    }
                </div>
                <div class="note">يمكن تطوير هذا القسم لاحقاً ليعرض منافسين آخرين</div>
            </div>
        </div>

        <!-- Locked rewards -->
        <div class="panel">
            <div class="panel-title">جوائز مقفلة</div>
            <div class="panel-body">
                <div class="rewards">
                    <div class="reward">🎁<span>🔒</span></div>
                    <div class="reward">🗡️<span>🔒</span></div>
                    <div class="reward">🛡️<span>🔒</span></div>
                </div>
                <div class="unlock">تفتح عند المستوى <b>10</b></div>
            </div>
        </div>

    </div>

</div>

<!-- =============================
     JavaScript للعجلة (Wheel of Fortune)
     ============================= -->
<script>
    (function(){
        const wheel = document.getElementById("dailyWheel");
        const spinBtn = document.getElementById("spinBtn");
        const taskBox = document.getElementById("taskBox");
        const taskText = document.getElementById("taskText");
        const taskNote = document.getElementById("taskNote");

        const tasks = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.WheelTasks));
        const segmentCount = tasks.length;
        const segmentAngle = 360 / segmentCount;
        let isSpinning = false;
        let currentRotation = 0;

        function showTask(index){
            taskBox.style.display = "block";
            taskText.textContent = tasks[index];
            taskNote.textContent = "مهمة اليوم";
        }

        if(!@Model.CanSpinWheel.ToString().ToLower() && @Model.SelectedTaskIndex >= 0){
            showTask(@Model.SelectedTaskIndex);
            spinBtn.textContent = "تم اختيار مهمة اليوم ✅";
            spinBtn.disabled = true;
        }

        spinBtn.addEventListener("click", function(){
            if(isSpinning) return;
            isSpinning = true;

            const pickedIndex = Math.floor(Math.random() * segmentCount);
            const targetAngle = (pickedIndex * segmentAngle) + (segmentAngle / 2);
            const extraSpins = 5;
            const finalRotation = (extraSpins * 360) + (360 - targetAngle);
            currentRotation += finalRotation;

            wheel.style.transform = `rotate(${currentRotation}deg)`;

            setTimeout(() => {
                isSpinning = false;
                showTask(pickedIndex);
                spinBtn.textContent = "تم اختيار مهمة اليوم ✅";
                spinBtn.disabled = true;
            }, 4200);
        });
    })();
</script>

