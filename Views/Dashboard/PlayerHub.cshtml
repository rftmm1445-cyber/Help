@model WebApplication4.Models.PlayerHubViewModel
@{
    ViewData["Title"] = "Game Dashboard";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<style>
    body {
        background: radial-gradient(circle, #1a103c 0%, #0b061f 100%);
        color: #ffffff;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        direction: rtl;
        text-align: right;
    }

    .profile-section {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(10px);
        border-bottom: 2px solid #6f42c1;
        padding: 15px;
    }

    .profile-avatar {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        border: 2px solid #00f2fe;
        box-shadow: 0 0 10px #00f2fe;
    }

    .stat-badge {
        background: linear-gradient(45deg, #f107a3, #7b2ff7);
        border-radius: 20px;
        padding: 5px 15px;
        font-size: 0.9rem;
        font-weight: bold;
    }

    .game-btn {
        background: linear-gradient(135deg, #2b1055, #7522ff);
        border: 2px solid #00f2fe;
        color: white;
        padding: 18px;
        font-size: 1.3rem;
        font-weight: bold;
        border-radius: 15px;
        margin-bottom: 15px;
        transition: all 0.3s ease;
        box-shadow: 0 5px 15px rgba(0, 242, 254, 0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 15px;
        width: 100%;
    }

        .game-btn:hover {
            transform: translateY(-5px) scale(1.02);
            box-shadow: 0 0 25px #00f2fe;
            background: linear-gradient(135deg, #00f2fe, #4facfe);
            color: #100a26;
        }

    .btn-exit {
        background: linear-gradient(135deg, #4d0519, #ff0044);
        border-color: #ff0044;
    }

    /* تصميم العجلة المحدث ليناسب 8 أقسام للمهام اليومية */
    .wheel-container {
        position: relative;
        width: 340px;
        height: 340px;
        margin: 0 auto;
    }

    .lucky-wheel {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        border: 8px solid #ffcc00;
        position: relative;
        overflow: hidden;
        transition: transform 6s cubic-bezier(0.25, 0.1, 0.1, 1);
        background: #111;
    }

    /* تقسيم العجلة هندسياً إلى 8 قطاعات (كل قطاع 45 درجة) */
    .slice {
        position: absolute;
        width: 50%;
        height: 50%;
        transform-origin: 100% 100%;
        left: 0;
        top: 0;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .slice-text {
        position: absolute;
        left: 15px;
        top: 45px;
        transform: rotate(22.5deg); /* موازنة زاوية النص ليقف بمنتصف القطاع تماماً */
        font-weight: bold;
        font-size: 0.75rem;
        color: white;
        text-shadow: 2px 2px 3px black;
        white-space: nowrap;
        max-width: 110px;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    /* توزيع الألوان والزوايا على القطاعات الثمانية */
    .s1 {
        transform: rotate(0deg) skewX(45deg);
        background: #ff0055;
    }

    .s2 {
        transform: rotate(45deg) skewX(45deg);
        background: #00ccff;
    }

    .s3 {
        transform: rotate(90deg) skewX(45deg);
        background: #9900ff;
    }

    .s4 {
        transform: rotate(135deg) skewX(45deg);
        background: #ffcc00;
    }

    .s5 {
        transform: rotate(180deg) skewX(45deg);
        background: #00ff66;
    }

    .s6 {
        transform: rotate(225deg) skewX(45deg);
        background: #ff6600;
    }

    .s7 {
        transform: rotate(270deg) skewX(45deg);
        background: #e600ac;
    }

    .s8 {
        transform: rotate(315deg) skewX(45deg);
        background: #4facfe;
    }

    .wheel-pointer {
        position: absolute;
        top: -15px;
        left: 50%;
        transform: translateX(-50%);
        width: 0;
        height: 0;
        border-left: 15px solid transparent;
        border-right: 15px solid transparent;
        border-top: 30px solid #ffcc00;
        z-index: 10;
    }

    .spin-center {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 65px;
        height: 65px;
        background: white;
        border-radius: 50%;
        color: #100a26;
        font-weight: bold;
        border: 3px solid #ffcc00;
        z-index: 12;
        cursor: pointer;
        box-shadow: 0 0 10px rgba(0,0,0,0.5);
    }
</style>

<div class="profile-section d-flex justify-content-between align-items-center mb-4">
    <div class="d-flex align-items-center gap-3">
        <img src="https://api.dicebear.com/7.x/bottts/svg?seed=@Model.Username" class="profile-avatar" alt="Avatar">
        <div>
            <h5 class="m-0 text-info">@Model.Username</h5>
            <small class="text-muted">المستوى: <span class="text-warning" id="displayLevel">@Model.Level</span></small>
            <span class="badge bg-secondary ms-2">الترتيب: #@Model.Rank</span>
        </div>
    </div>
    <div class="d-flex gap-2">
        <span class="stat-badge"><i class="bi bi-trophy-fill text-warning me-1"></i> <span id="displayScore">@Model.Score</span> نقطة</span>
    </div>
</div>

<div class="container my-3">
    <div class="row align-items-center g-5">

        <div class="col-md-6 order-2 order-md-1">
            <div class="px-3">
                <button class="game-btn"><i class="bi bi-globe-americas fs-3"></i> <span>1. اختيار دولة</span></button>


                <a asp-action="Randomm" asp-controller="the4" class="game-btn text-decoration-none">
                    <i class="bi bi-shuffle fs-3"></i>
                    <span>2. عشوائي</span>
                </a>
                <button class="game-btn"><i class="bi bi-geo-alt-fill fs-3"></i> <span>3. مواقعي</span></button>
                <button class="game-btn btn-exit mt-4"><i class="bi bi-box-arrow-right fs-3"></i> <span>4. الخروج</span></button>
            </div>
        </div>

        <div class="col-md-6 order-1 order-md-2 text-center">
            <div class="p-4 rounded-4" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05)">
                <h4 class="text-warning mb-4"><i class="bi bi-stars"></i> عجلة المهام اليومية <i class="bi bi-stars"></i></h4>

                <div class="wheel-container mb-4">
                    <div class="wheel-pointer"></div>
                    <div class="lucky-wheel" id="wheel">
                        @for (int i = 0; i < Model.WheelTasks.Count; i++)
                        {
                            <div class="slice s@(i + 1)"><span class="slice-text">@Model.WheelTasks[i]</span></div>
                        }
                    </div>
                    <button class="spin-center d-flex align-items-center justify-content-center" id="spinBtn" onclick="spinWheel()">إبدأ</button>
                </div>
                <p class="text-muted small" id="wheelStatus">مسموح لك بمهمة واحدة كل يوم!</p>
            </div>
        </div>

    </div>
</div>

<script>
    // جلب المؤشر المختار مسبقاً من الـ Controller بناءً على حسابات السيرفر
    const serverSelectedIndex = @Model.SelectedTaskIndex;
    const canSpinFromServer = @Model.CanSpinWheel.ToString().ToLower();
    const taskText = "@Html.Raw(Model.SelectedTaskText)";

    document.addEventListener("DOMContentLoaded", function () {
        // التحقق مما إذا كان اللاعب قد لف العجلة اليوم بناءً على السيرفر
        if (!canSpinFromServer) {
            document.getElementById("wheelStatus").innerText = "لقد حصلت على مهمتك اليومية بالفعل! عد غداً.";
            document.getElementById('spinBtn').disabled = true;
        }
    });

    function spinWheel() {
        if (!canSpinFromServer) {
            alert("لقد حصلت على مهمتك اليومية بالفعل! عد غداً.");
            return;
        }

        const wheel = document.getElementById('wheel');
        const btn = document.getElementById('spinBtn');
        btn.disabled = true;

        // حساب عدد الدرجات ليدور العجلة 6 دورات كاملة ثم يقف على القطاع المحدد من السيرفر بدقة
        // القطاعات مقسمة على 45 درجة، والاتجاه معدل ليتوافق مع المؤشر العلوي
        const degreesPerSlice = 45;
        const targetAngle = 360 - (serverSelectedIndex * degreesPerSlice);
        const totalDegrees = 2160 + targetAngle; // 6 دورات كاملة + زاوية الهدف

        wheel.style.transform = `rotate(${totalDegrees}deg)`;

        setTimeout(() => {
            alert(`مهمتك اليوم هي:\n🎯 "${taskText}"`);

            // في حال رغبت بإرسال تأكيد الحفظ أو تحديث فوري للنقاط إلى سيرفر الـ Gameround
            if(taskText.includes("50 نقطة")) {
                 claimPrizeFromServer(50);
            }

            document.getElementById("wheelStatus").innerText = "تم تحديد مهمة اليوم بنجاح!";
        }, 6000); // 6 ثوانٍ من الدوران الحماسي السريع والمطول
    }

    function claimPrizeFromServer(points) {
        fetch('/Gameround/ClaimWheelPrize', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: `points=${points}`
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                document.getElementById("displayScore").innerText = data.newScore;
            }
        });
    }
</script>